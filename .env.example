# ============================
# 应用配置
# ============================

# 应用调试模式（生产环境设置为 false）
APP_DEBUG=true

# 应用环境（development / production）
APP_ENV=development

# 应用密钥（用于加密，务必修改）
# 生成方法：php -r "echo 'base64:' . base64_encode(random_bytes(32)) . PHP_EOL;"
APP_KEY=base64:your_app_key_here

# 应用 URL
APP_URL=http://localhost:8789

# API 域名
API_DOMAIN=http://api-test.1ting.cn/

# 货币单位（TWD / CNY / USD 等）
CURRENCY=TWD

# ============================
# 数据库配置
# ============================

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# 读写分离配置（可选）
DB_READ_HOST=127.0.0.1
DB_READ_USERNAME=your_username
DB_READ_PASSWORD=your_password

DB_WRITE_HOST=127.0.0.1
DB_WRITE_USERNAME=your_username
DB_WRITE_PASSWORD=your_password

# ============================
# Redis 配置
# ============================

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================
# MongoDB 配置
# ============================

MONGODB_HOST=127.0.0.1
MONGODB_PORT=27017
MONGODB_DATABASE=luck3
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_AUTH_DATABASE=admin

# ============================
# WebSocket Push 服务配置
# ============================

# WebSocket 连接地址（前端使用）
# 本地开发：ws://127.0.0.1:3131
# 生产环境：ws://your-domain.com:3131 或 wss://your-domain.com:3131（SSL）
WS_URL=ws://127.0.0.1:3131

# Push API 地址（后端发送消息使用）
# 本地环境：http://127.0.0.1:3232
# 远程服务器：http://api-server-ip:3232
PUSH_API_URL=http://127.0.0.1:3232

# Push 应用密钥（需要与 Push 服务器配置一致）
# 注意：生产环境务必修改为独立的密钥
PUSH_APP_KEY=20f94408fc4c52845f162e92a253c7a3
PUSH_APP_SECRET=a8c092135db24c9695dcdb5bbd88cd18

# ============================
# Google Cloud Storage 配置
# ============================

# Google Cloud 密钥文件路径
GOOGLE_CLOUD_KEY_FILE=your-project-keyfile.json

# Google Cloud 项目 ID
GOOGLE_CLOUD_PROJECT_ID=your-project-id

# Google Cloud Storage 存储桶名称
GOOGLE_CLOUD_STORAGE_BUCKET=your-bucket-name

# 存储前缀（用于区分环境：dev / test / prod）
GOOGLE_CLOUD_STORAGE_PREFIX=dev

# ============================
# Talk 第三方服务配置
# ============================

TALK_CHANNEL_ID=your_channel_id
TALK_CHANNEL_SECRET=your_channel_secret
TALK_CALLBACK_URL=
TALK_DOMAIN=http://your-talk-domain.com

# ============================
# IP 白名单配置
# ============================

# 是否启用 IP 白名单验证（true/false）
IP_WHITELIST_ENABLE=false

# ============================
# Cloudflare Turnstile 人机验证
# ============================

TURNSTILE_ENABLED=false
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ============================
# 设备安全配置
# ============================

# 设备系统密钥（务必修改为64位随机字符串）
# 生成方法：php -r "echo bin2hex(random_bytes(32)) . PHP_EOL;"
DEVICE_SECRET_KEY=change_this_to_random_string_1234567890abcdef

# 验证服务器配置
DEVICE_AUTH_ENABLED=true
DEVICE_AUTH_HOST=10.0.0.100
DEVICE_AUTH_PORT=9501
DEVICE_AUTH_PROTOCOL=https

# 令牌配置
DEVICE_TOKEN_TTL=1800
DEVICE_TOKEN_ALGORITHM=HS256
DEVICE_TOKEN_REFRESH_THRESHOLD=600

# 安全配置
DEVICE_TIMESTAMP_TOLERANCE=300
DEVICE_ENABLE_REQUEST_SIGNATURE=false

# 限流配置
DEVICE_AUTH_MAX_ATTEMPTS=10
DEVICE_AUTH_FAIL_WINDOW=3600
DEVICE_AUTH_BAN_DURATION=86400

# 监控配置
DEVICE_ENABLE_ANOMALY_DETECTION=true
DEVICE_ENABLE_VERBOSE_LOGGING=false

# 告警配置
DEVICE_ALERT_CHANNELS=log
DEVICE_DINGTALK_WEBHOOK=
DEVICE_WECHAT_WEBHOOK=
DEVICE_ALERT_EMAIL=

